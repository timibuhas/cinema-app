# ── Required ──────────────────────────────────────────────────────────────────
# Parolă puternică pentru baza de date (ex: openssl rand -hex 32)
POSTGRES_PASSWORD=change_me

# Cheie secretă JWT — minim 32 caractere (ex: openssl rand -hex 32)
SECRET_KEY=change_me_at_least_32_characters_long

# ── Opțional — valori implicite afișate ───────────────────────────────────────
POSTGRES_DB=cinema
POSTGRES_USER=cinema_user

# Portul pe care va asculta nginx pe mașina gazdă
APP_PORT=80

# Origini CORS suplimentare, separate prin virgulă (ex: https://cinema.example.com)
# Nu este nevoie dacă accesezi aplicația de pe același domeniu/IP.
CORS_ORIGINS=

# ── Ollama (chatbot AI) ───────────────────────────────────────────────────────
# În Docker pe Windows/Mac, host.docker.internal ajunge la Ollama de pe mașina gazdă.
# Pe Linux: înlocuiește cu IP-ul real al gazdei sau adaugă --add-host=host.docker.internal:host-gateway în docker-compose.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:4b

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tapticketcinema@gmail.com
SMTP_PASSWORD=ddgtqdjcpkocbbtm
EMAIL_FROM_NAME=TapTicket
EMAIL_FROM=tapticketcinema@gmail.com
